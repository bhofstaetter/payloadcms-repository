{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "noEmit": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "types": ["vitest"],
        "paths": {
            "@/*": ["./src/*"],
            "@test/*": ["./test/*"]
        }
    },
    "include": ["src/**/*.ts", "test/**/*.ts"],
    "exclude": ["node_modules", "dist", "test/helpers/payload.test.types.ts"]
}
